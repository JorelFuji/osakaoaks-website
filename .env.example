# Environment Variables Example
# Copy this to .env and fill in your values (NEVER commit .env to Git)

# SSH Configuration
SSH_HOST=osakaoaks.org
SSH_USER=osakuqbj
SSH_PORT=21098

# GitHub Repository
GITHUB_REPO=YOUR_USERNAME/osakaoaks-website

# Deployment Paths
PROD_PATH=/home/osakuqbj/public_html/
DEV_PATH=/home/osakuqbj/jarrelspiller.osakaoaks.org/

# URLs
PROD_URL=https://osakaoaks.org
DEV_URL=https://jarrelspiller.osakaoaks.org

# cPanel
CPANEL_URL=https://premium187.web-hosting.com:2083
CPANEL_USERNAME=osakuqbj
