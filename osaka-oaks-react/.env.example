# Osaka Oaks - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================
# APPLICATION
# ============================================
VITE_APP_NAME=Osaka Oaks LLC
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=production

# ============================================
# API ENDPOINTS
# ============================================
VITE_API_BASE_URL=https://api.osakaoaks.org
VITE_API_TIMEOUT=30000

# ============================================
# FIREBASE (if using)
# ============================================
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# VA API (Department of Veterans Affairs)
# ============================================
VITE_VA_API_KEY=your_va_api_key_here
VITE_VA_API_BASE_URL=https://api.va.gov
VITE_VA_CLIENT_ID=your_client_id
VITE_VA_CLIENT_SECRET=your_client_secret_DO_NOT_EXPOSE

# ============================================
# OAUTH & AUTHENTICATION
# ============================================
VITE_OAUTH_REDIRECT_URI=https://osakaoaks.org/auth/callback
VITE_OAUTH_CLIENT_ID=your_oauth_client_id
# DO NOT put client secret in frontend - use backend only!

# ============================================
# COMPANY INFORMATION
# ============================================
VITE_COMPANY_NAME=Osaka Oaks LLC
VITE_COMPANY_UEI=MUGPMK51DFB4
VITE_COMPANY_CAGE=11WZ2
VITE_COMPANY_PHONE=(832) 847-5186
VITE_COMPANY_EMAIL=jarrel.spiller@osakaoaks.org
VITE_COMPANY_ADDRESS=6212 Belgrave Dr, Austin, Texas 78747

# ============================================
# FEATURE FLAGS
# ============================================
VITE_FEATURE_CHARTS_ENABLED=true
VITE_FEATURE_PWA_ENABLED=true
VITE_FEATURE_ANALYTICS_ENABLED=true
VITE_FEATURE_VETERAN_PORTAL=false

# ============================================
# ANALYTICS
# ============================================
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_GTM_ID=GTM-XXXXXXX

# ============================================
# DOCKER / KUBERNETES
# ============================================
# These are used in backend/infrastructure only
DOCKER_REGISTRY=registry.osakaoaks.org
K8S_NAMESPACE=osaka-oaks-prod
K8S_CPU_LIMIT=500m
K8S_MEMORY_LIMIT=512Mi

# ============================================
# BACKEND API KEYS (Server-side only!)
# ============================================
# NEVER expose these in frontend!
# These should only be in backend .env
API_SECRET_KEY=your_secret_key_here_backend_only
JWT_SECRET=your_jwt_secret_backend_only
DATABASE_URL=postgresql://user:pass@host:5432/dbname
